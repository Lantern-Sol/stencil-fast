      "blocks": {
        "value_AWYj4i": {
          "type": "value",
          "settings": {
            "icon": "people",
            "title": "People-Centric",
            "text": "Our crew and customers form one extended team. Every piece of feedback drives how we evolve — because better markings start with better relationships."
          }
        },
        "value_CaLJnT": {
          "type": "value",
          "settings": {
            "icon": "tech",
            "title": "Tech-Obsessed",
            "text": "Decades of technological evolution with limitless innovation ahead. We invest in better processes, better materials, and better tools — always."
          }
        },
        "value_8WQ97P": {
          "type": "value",
          "settings": {
            "icon": "shield",
            "title": "Absolutely Uncompromising",
            "text": "Better. Faster. Stronger. We don't trade off quality for cost or speed. Every stencil that leaves our facility meets the standard. No exceptions."
          }
        }
      },
      "block_order": [
        "value_AWYj4i",
