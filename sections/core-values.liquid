{%- liquid
  assign background_color = section.settings.background_color | default: '#FDFDFC'
  assign card_color = section.settings.card_color | default: '#F9FAF5'
  assign heading_color = section.settings.heading_color | default: '#393E41'
  assign accent_color = section.settings.accent_color | default: '#E94F37'
  assign icon_color = section.settings.icon_color | default: '#FFFFFF'
  assign text_color = section.settings.text_color | default: '#393E41'
-%}

<div
  id="CoreValues-{{ section.id }}"
  class="core-values"
  style="
    --cv-bg: {{ background_color }};
    --cv-card-bg: {{ card_color }};
    --cv-heading: {{ heading_color }};
    --cv-accent: {{ accent_color }};
    --cv-icon: {{ icon_color }};
    --cv-text: {{ text_color }};
    --cv-count: {{ section.blocks.size | at_least: 1 }};
    --padding-block-start: {{ section.settings.padding-block-start }}px;
    --padding-block-end: {{ section.settings.padding-block-end }}px;
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="core-values__container">
    <!-- Heading -->
    <div class="core-values__header">
      {% if section.settings.eyebrow != blank %}
        <p class="core-values__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="core-values__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="core-values__description">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    <!-- Cards -->
    {% if section.blocks.size > 0 %}
      <core-values-stack
        class="core-values__cards"
        data-stacking="{{ section.settings.enable_mobile_stacking }}"
      >
        {% for block in section.blocks %}
          <div
            class="core-values__card"
            style="--cv-index: {{ forloop.index0 }};"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.icon != 'none' %}
              <span class="core-values__badge" aria-hidden="true">
                {% case block.settings.icon %}
                  {% when 'people' %}
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 15.75V14.25C12 13.4544 11.6839 12.6913 11.1213 12.1287C10.5587 11.5661 9.79565 11.25 9 11.25H4.5C3.70435 11.25 2.94129 11.5661 2.37868 12.1287C1.81607 12.6913 1.5 13.4544 1.5 14.25V15.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M6.75 8.25C8.40685 8.25 9.75 6.90685 9.75 5.25C9.75 3.59315 8.40685 2.25 6.75 2.25C5.09315 2.25 3.75 3.59315 3.75 5.25C3.75 6.90685 5.09315 8.25 6.75 8.25Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16.5 15.75V14.25C16.4995 13.5853 16.2783 12.9396 15.871 12.4142C15.4638 11.8889 14.8936 11.5137 14.25 11.3475" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 2.3475C12.6453 2.51273 13.2173 2.88803 13.6257 3.41423C14.0342 3.94044 14.2559 4.58762 14.2559 5.25375C14.2559 5.91988 14.0342 6.56706 13.6257 7.09327C13.2173 7.61947 12.6453 7.99477 12 8.16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% when 'tech' %}
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M13.5 3H4.5C3.67157 3 3 3.67157 3 4.5V13.5C3 14.3284 3.67157 15 4.5 15H13.5C14.3284 15 15 14.3284 15 13.5V4.5C15 3.67157 14.3284 3 13.5 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M10.5 6.75H7.5C7.08579 6.75 6.75 7.08579 6.75 7.5V10.5C6.75 10.9142 7.08579 11.25 7.5 11.25H10.5C10.9142 11.25 11.25 10.9142 11.25 10.5V7.5C11.25 7.08579 10.9142 6.75 10.5 6.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M11.25 1.5V3M11.25 15V16.5M1.5 11.25H3M1.5 6.75H3M15 11.25H16.5M15 6.75H16.5M6.75 1.5V3M6.75 15V16.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% when 'shield' %}
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M15 9.75C15 13.5 12.375 15.375 9.255 16.4625C9.09162 16.5179 8.91415 16.5152 8.7525 16.455C5.625 15.375 3 13.5 3 9.75V4.5C3 4.30109 3.07902 4.11032 3.21967 3.96967C3.36032 3.82902 3.55109 3.75 3.75 3.75C5.25 3.75 7.125 2.85 8.43 1.71C8.58889 1.57425 8.79102 1.49966 9 1.49966C9.20898 1.49966 9.41111 1.57425 9.57 1.71C10.8825 2.8575 12.75 3.75 14.25 3.75C14.4489 3.75 14.6397 3.82902 14.7803 3.96967C14.921 4.11032 15 4.30109 15 4.5V9.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M6.75 9L8.25 10.5L11.25 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% when 'custom' %}
                    {% if block.settings.custom_icon != blank %}
                      {{ block.settings.custom_icon | image_url: width: 36 | image_tag: alt: block.settings.custom_icon.alt, loading: 'lazy' }}
                    {% endif %}
                {% endcase %}
              </span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="core-values__title">{{ block.settings.title | escape }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="core-values__text">{{ block.settings.text | escape }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </core-values-stack>
    {% endif %}
  </div>
</div>

<style>
  .core-values {
    background-color: var(--cv-bg);
    padding-block-start: var(--padding-block-start, 56px);
    padding-block-end: var(--padding-block-end, 56px);
    overflow: clip;
  }

  .core-values__container {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: var(--page-width, 1500px);
    margin-inline: auto;
    padding-inline: var(--page-margin, 40px);
  }

  /* ---------- Heading ---------- */
  .core-values__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .core-values__eyebrow {
    margin: 0;
    color: var(--cv-heading);
    font-size: 32px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.64px;
    text-transform: uppercase;
  }

  .core-values__heading {
    margin: 0;
    margin-block-start: -12px;
    color: var(--cv-accent);
    font-size: 48px;
    font-weight: 500;
    font-style: italic;
    line-height: 1.2;
    letter-spacing: 0.96px;
    text-transform: uppercase;
  }

  .core-values__description {
    max-width: 720px;
    color: var(--cv-text);
    font-family: var(--secondary-font);
    font-size: 16px;
    line-height: 1.4;
  }

  .core-values__description p {
    margin: 0;
  }

  /* ---------- Cards ---------- */
.core-values__cards {
	display: flex;
	gap: 24px;
	align-items: stretch;
}

.core-values__card {
	display: flex;
	flex-direction: column;
	gap: 16px;
	align-items: flex-start;
	padding: 40px;
	background-color: var(--cv-card-bg);
	border-radius: 60px 0 60px 0;
	box-shadow: 0 4px 2px 0 rgba(0, 0, 0, 0.05);
	width: 33%;
}

  .core-values__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background-color: var(--cv-accent);
    color: var(--cv-icon);
  }

  .core-values__badge svg {
    width: 18px;
    height: 18px;
  }

  .core-values__badge img {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .core-values__title {
    margin: 0;
    color: var(--cv-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .core-values__text {
    margin: 0;
    color: var(--cv-text);
    font-family: var(--secondary-font);
    font-size: 16px;
    line-height: 1.4;
  }

  /* ---------- Mobile ---------- */
  @media only screen and (max-width: 749px) {
    .core-values {
      padding-block-start: var(--padding-block-start-mobile, 48px);
      padding-block-end: var(--padding-block-end-mobile, 48px);
    }

    .core-values__container {
      gap: 24px;
    }

    .core-values__eyebrow {
      font-size: 24px;
      letter-spacing: 0.48px;
    }

    .core-values__heading {
      margin-block-start: -8px;
      font-size: 32px;
      letter-spacing: 0.64px;
    }

    .core-values__cards {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .core-values__card {
      padding: 24px;
      width: 100%;
      box-sizing: border-box;
    }

    .core-values__title {
      font-size: 18px;
      letter-spacing: 0.36px;
    }

    /* Stacking parallax cards */
    .core-values__cards[data-stacking='true'] .core-values__card {
      position: sticky;
      top: calc(90px + var(--cv-index, 0) * 10px);
      transform-origin: center top;
      will-change: transform;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .core-values__cards[data-stacking='true'] .core-values__card {
      position: relative;
      top: auto;
      transform: none !important;
    }
  }
</style>

<script>
  /**
   * CoreValuesStack custom element
   * Mobile-only stacking parallax: as each card scrolls up and sticks,
   * the next card slides over it while the covered card scales down.
   */
  class CoreValuesStack extends HTMLElement {
    constructor() {
      super();
      this.onScroll = this.onScroll.bind(this);
      this.setup = this.setup.bind(this);
      this.ticking = false;
    }

    connectedCallback() {
      if (this.dataset.stacking !== 'true') return;

      this.cards = Array.from(this.querySelectorAll('.core-values__card'));
      if (this.cards.length < 2) return;

      this.mobileQuery = window.matchMedia('(max-width: 749px)');
      this.reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      this.mobileQuery.addEventListener('change', this.setup);
      this.reducedMotion.addEventListener('change', this.setup);
      this.setup();
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.onScroll);
      if (this.mobileQuery) this.mobileQuery.removeEventListener('change', this.setup);
      if (this.reducedMotion) this.reducedMotion.removeEventListener('change', this.setup);
    }

    setup() {
      if (this.mobileQuery.matches && !this.reducedMotion.matches) {
        window.addEventListener('scroll', this.onScroll, { passive: true });
        this.onScroll();
      } else {
        window.removeEventListener('scroll', this.onScroll);
        this.cards.forEach((card) => {
          card.style.transform = '';
          card.style.opacity = '';
        });
      }
    }

    onScroll() {
      if (this.ticking) return;
      this.ticking = true;

      requestAnimationFrame(() => {
        this.cards.forEach((card, index) => {
          const next = this.cards[index + 1];
          if (!next) return;

          const rect = card.getBoundingClientRect();
          const nextRect = next.getBoundingClientRect();

          // How far the next card has travelled over this one (0 to 1)
          const overlap = rect.bottom - nextRect.top;
          const progress = Math.min(Math.max(overlap / rect.height, 0), 1);

          const scale = 1 - progress * 0.06;
          card.style.transform = 'scale(' + scale.toFixed(4) + ')';
          card.style.opacity = (1 - progress * 0.35).toFixed(3);
        });

        this.ticking = false;
      });
    }
  }

  if (!customElements.get('core-values-stack')) {
    customElements.define('core-values-stack', CoreValuesStack);
  }
</script>

{% schema %}
{
  "name": "Core Values",
  "tag": "section",
  "class": "core-values-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Three principles,"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "no exceptions."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our core values drive us to evolve our product and customer experience. A culture of constant improvement is our day-to-day. It’s been like that since day one.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FDFDFC"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card Background Color",
      "default": "#F9FAF5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#393E41"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#E94F37"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#393E41"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_stacking",
      "label": "Enable Stacking Parallax Effect",
      "info": "Cards stack over each other while scrolling on mobile.",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "people", "label": "People" },
            { "value": "tech", "label": "Technology" },
            { "value": "shield", "label": "Shield" },
            { "value": "custom", "label": "Custom Image" },
            { "value": "none", "label": "None" }
          ],
          "default": "people"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Icon Image",
          "info": "Used when Icon is set to Custom Image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "People-Centric"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Our crew and customers form one extended team. Every piece of feedback drives how we evolve — because better markings start with better relationships."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Core Values",
      "category": "Text",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "people",
            "title": "People-Centric",
            "text": "Our crew and customers form one extended team. Every piece of feedback drives how we evolve — because better markings start with better relationships."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "tech",
            "title": "Tech-Obsessed",
            "text": "Decades of technological evolution with limitless innovation ahead. We invest in better processes, better materials, and better tools — always."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "shield",
            "title": "Absolutely Uncompromising",
            "text": "Better. Faster. Stronger. We don't trade off quality for cost or speed. Every stencil that leaves our facility meets the standard. No exceptions."
          }
        }
      ]
    }
  ]
}
{% endschema %}
